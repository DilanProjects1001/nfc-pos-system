# =====================================================================
#  multi-agent-desktop-orchestrator — environment template
#  Copy to .env and fill in. Startup is DENY-BY-DEFAULT (dotenv-safe):
#  a missing required key makes the process fail fast at boot.
#  NEVER commit the real .env or the Firebase service-account file.
# =====================================================================

# --- Telegram control channel ---
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
ALLOWED_USER_ID="your_telegram_user_id"

# --- LLM providers (remote) ---
GROQ_API_KEY="your_groq_api_key"
OPENROUTER_API_KEY="your_openrouter_api_key"

# --- Local LLMs (Ollama) ---
# OLLAMA_HOST="http://127.0.0.1:11434"

# --- Optional integrations ---
ELEVENLABS_API_KEY="your_elevenlabs_api_key"
FIREBASE_SERVICE_ACCOUNT="./service-account.json"
