# ============================================================
# nfc-pos-system — Environment Configuration
# Copy this file to .env and fill in real values.
#   cp .env.example .env
# The .env file is gitignored and must never be committed.
# ============================================================

# REQUIRED. Secret used to sign and verify JWT auth tokens.
# The server REFUSES to start if this is unset (deny-by-default).
# Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string

# Port the HTTP API + web UIs (admin / POS) listen on. Default: 3000
PORT=3000

# Runtime environment: development | production
NODE_ENV=development
